*.class
*.log
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
target/

# ---- JVM crash logs ----
hs_err_pid*
replay_pid*

# ---- IDE ----
.idea/
*.iml
.vscode/
.worktrees/
.cursor/playwright-output/
.classpath
.project
.settings/
.factorypath
.springBeans

# ---- Frontend (ai-admin-front) ----
ai-admin-front/node_modules/
ai-admin-front/dist/
ai-admin-front/.vite/

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local
**/application-local.yml
**/application-secret.yml
ai-admin-front/nul

OtherOutstandingProjects/
