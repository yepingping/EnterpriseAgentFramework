{
  "mcpServers": {
    "playwright": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "msedge",
        "--caps",
        "vision,devtools",
        "--output-dir",
        ".cursor/playwright-output",
        "--output-mode",
        "file"
      ]
    },
    "dbhub_ai_mysql": {
      "command": "dbhub.cmd",
      "args": [
        "--transport",
        "stdio",
        "--config",
        ".cursor/dbhub-ai-mysql.toml"
      ]
    }
  }
}
